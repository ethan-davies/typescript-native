# Dependencies
node_modules/
.pnpm-store/

# Bundled OpenSSL builds (sources/cache live under ~/.cache/sonite)
packages/runtime/deps/openssl/**
!packages/runtime/deps/openssl/.gitkeep
!packages/runtime/deps/openssl/README.md

# OpenSSL static libs staged into prebuilt/ by installHostPrebuilt
packages/runtime/prebuilt/*/libssl.a
packages/runtime/prebuilt/*/libcrypto.a
packages/runtime/prebuilt/*/libssl.lib
packages/runtime/prebuilt/*/libcrypto.lib
packages/runtime/prebuilt/*/ssl.lib
packages/runtime/prebuilt/*/crypto.lib

# Build output
dist/
*.tsbuildinfo

# Test / coverage
coverage/
.vitest/

# Environment
.env
.env.*
!.env.example

# Editor / OS
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
!.vscode/tasks.json

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# LLVM intermediate artifacts (generated during compile)
*.ll
*.bc
*.o
*.out
!examples/**/*.sn

# Local notes (not published)
progress.md
