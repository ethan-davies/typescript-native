{
  "name": "sonite-vscode",
  "displayName": "Sonite",
  "description": "Language support for Sonite (.sn) — syntax highlighting, IntelliSense, and language server",
  "version": "0.1.0",
  "license": "MIT",
  "author": "Ethan Davies",
  "publisher": "sonite",
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#0F172A",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ethan-davies/sonite.git",
    "directory": "packages/vscode"
  },
  "bugs": {
    "url": "https://github.com/ethan-davies/sonite/issues"
  },
  "homepage": "https://github.com/ethan-davies/sonite/tree/main/packages/vscode",
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=20"
  },
  "categories": [
    "Programming Languages",
    "Formatters",
    "Linters"
  ],
  "keywords": [
    "sn",
    "sonite",
    "lsp",
    "language-server",
    "textmate"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:sn"
  ],
  "contributes": {
    "configuration": {
      "title": "Sonite",
      "properties": {
        "sonite.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Traces the communication between VS Code and the Sonite language server."
        }
      }
    },
    "languages": [
      {
        "id": "sn",
        "aliases": [
          "Sonite",
          "sn"
        ],
        "extensions": [
          ".sn"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "sn",
        "scopeName": "source.sn",
        "path": "./syntaxes/sn.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "build": "node scripts/bundle.mjs && node --check tests/grammar.test.mjs && node -e \"JSON.parse(require('fs').readFileSync('syntaxes/sn.tmLanguage.json','utf8')); JSON.parse(require('fs').readFileSync('language-configuration.json','utf8')); console.log('ok')\"",
    "clean": "rm -rf dist stdlib node_modules/.cache *.vsix",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test tests/grammar.test.mjs",
    "package": "pnpm run build && vsce package --no-dependencies",
    "vscode:prepublish": "pnpm run build"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.25.12",
    "typescript": "^5.8.3",
    "vscode-oniguruma": "^2.0.1",
    "vscode-textmate": "^9.2.0"
  }
}
