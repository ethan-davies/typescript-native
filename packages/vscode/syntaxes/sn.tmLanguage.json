{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Sonite",
  "scopeName": "source.sn",
  "fileTypes": ["sn"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#chars" },
    { "include": "#numbers" },
    { "include": "#imports" },
    { "include": "#declarations" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#builtins" },
    { "include": "#primitives" },
    { "include": "#operators" },
    { "include": "#punctuation" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.sn",
          "match": "//.*$"
        },
        {
          "name": "comment.block.sn",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.sn",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.sn",
          "match": "\\\\[ntr\\\\\"'0]"
        }
      ]
    },
    "chars": {
      "name": "string.quoted.single.sn",
      "begin": "'",
      "end": "'",
      "patterns": [
        {
          "name": "constant.character.escape.sn",
          "match": "\\\\[ntr\\\\\"'0]"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.sn",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.sn",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "imports": {
      "patterns": [
        {
          "name": "meta.import.sn",
          "begin": "\\b(import)\\b",
          "beginCaptures": {
            "1": { "name": "keyword.control.import.sn" }
          },
          "end": "(?=;|$)",
          "patterns": [
            { "include": "#comments" },
            { "include": "#strings" },
            {
              "match": "\\b(from|as)\\b",
              "name": "keyword.control.import.sn"
            },
            {
              "match": "\\*",
              "name": "constant.language.import-export-all.sn"
            },
            {
              "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\b",
              "name": "variable.other.readwrite.sn"
            },
            {
              "match": "[{},]",
              "name": "punctuation.definition.block.sn"
            }
          ]
        },
        {
          "match": "\\b(export)\\b",
          "name": "keyword.control.export.sn"
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "match": "\\b(function)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": { "name": "storage.type.function.sn" },
            "2": { "name": "entity.name.function.sn" }
          }
        },
        {
          "match": "\\b(struct)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": { "name": "storage.type.struct.sn" },
            "2": { "name": "entity.name.type.struct.sn" }
          }
        },
        {
          "match": "\\b(enum)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": { "name": "storage.type.enum.sn" },
            "2": { "name": "entity.name.type.enum.sn" }
          }
        },
        {
          "match": "\\b(abstract)\\s+(class)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": { "name": "storage.modifier.sn" },
            "2": { "name": "storage.type.class.sn" },
            "3": { "name": "entity.name.type.class.sn" }
          }
        },
        {
          "match": "\\b(class)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": { "name": "storage.type.class.sn" },
            "2": { "name": "entity.name.type.class.sn" }
          }
        },
        {
          "match": "\\b(interface)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": { "name": "storage.type.interface.sn" },
            "2": { "name": "entity.name.type.interface.sn" }
          }
        },
        {
          "match": "\\b(type)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": { "name": "storage.type.alias.sn" },
            "2": { "name": "entity.name.type.alias.sn" }
          }
        },
        {
          "match": "\\b(constructor)\\b",
          "name": "storage.type.constructor.sn"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "match": "\\b(if|elseif|else|while|for|switch|case|default|break|continue|return|throw|try|catch|finally|await)\\b",
          "name": "keyword.control.sn"
        },
        {
          "match": "\\b(let|const|async)\\b",
          "name": "storage.type.sn"
        },
        {
          "match": "\\b(abstract|public|private|readonly|static)\\b",
          "name": "storage.modifier.sn"
        },
        {
          "match": "\\b(extends|implements|in)\\b",
          "name": "keyword.control.inheritance.sn"
        },
        {
          "match": "\\b(new|typeof|keyof|is|as)\\b",
          "name": "keyword.operator.expression.sn"
        },
        {
          "match": "\\b(this|super)\\b",
          "name": "variable.language.sn"
        },
        {
          "match": "\\b(function|struct|enum|class|interface|type)\\b",
          "name": "storage.type.sn"
        },
        {
          "match": "\\b(from)\\b",
          "name": "keyword.control.import.sn"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "match": "\\b(true|false)\\b",
          "name": "constant.language.boolean.sn"
        },
        {
          "match": "\\b(null)\\b",
          "name": "constant.language.null.sn"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "match": "\\b(print|createMap)\\b(?=\\s*\\()",
          "name": "support.function.builtin.sn"
        },
        {
          "match": "\\b(Error)\\b",
          "name": "support.class.builtin.sn"
        }
      ]
    },
    "primitives": {
      "match": "\\b(i32|i64|f32|f64|bool|string|char|void)\\b",
      "name": "support.type.primitive.sn"
    },
    "operators": {
      "patterns": [
        {
          "match": "(\\+\\+|\\-\\-|\\+\\=|\\-\\=)",
          "name": "keyword.operator.assignment.compound.sn"
        },
        {
          "match": "(=\\=|!=|<=|>=|<|>)",
          "name": "keyword.operator.comparison.sn"
        },
        {
          "match": "(&&|\\|\\|)",
          "name": "keyword.operator.logical.sn"
        },
        {
          "match": "(\\?\\?)",
          "name": "keyword.operator.nullish.sn"
        },
        {
          "match": "(\\?\\.)",
          "name": "keyword.operator.optional.sn"
        },
        {
          "match": "(=>)",
          "name": "storage.type.function.arrow.sn"
        },
        {
          "match": "(\\?\\[)",
          "name": "keyword.operator.optional.sn"
        },
        {
          "match": "([+\\-*/%])",
          "name": "keyword.operator.arithmetic.sn"
        },
        {
          "match": "(=)",
          "name": "keyword.operator.assignment.sn"
        },
        {
          "match": "(!)",
          "name": "keyword.operator.logical.sn"
        },
        {
          "match": "(\\?)",
          "name": "keyword.operator.ternary.sn"
        },
        {
          "match": "(&)",
          "name": "keyword.operator.bitwise.sn"
        },
        {
          "match": "(\\|)",
          "name": "keyword.operator.bitwise.sn"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "match": "[{}]",
          "name": "punctuation.definition.block.sn"
        },
        {
          "match": "[\\[\\]]",
          "name": "punctuation.definition.bracket.sn"
        },
        {
          "match": "[()]",
          "name": "punctuation.definition.parameters.sn"
        },
        {
          "match": ";",
          "name": "punctuation.terminator.statement.sn"
        },
        {
          "match": ",",
          "name": "punctuation.separator.comma.sn"
        },
        {
          "match": ":",
          "name": "punctuation.separator.colon.sn"
        },
        {
          "match": "\\.",
          "name": "punctuation.accessor.sn"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.sn" }
          }
        },
        {
          "match": "\\b([A-Z][A-Za-z0-9_]*)\\b",
          "name": "entity.name.type.sn"
        },
        {
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\b",
          "name": "variable.other.readwrite.sn"
        }
      ]
    }
  }
}
