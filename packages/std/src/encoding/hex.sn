extern function sn_hex_encode(data: string): string;
extern function sn_hex_decode(data: string): string | null;

export function hexEncode(data: string): string {
  return sn_hex_encode(data);
}

export function hexDecode(data: string): string {
  let result = sn_hex_decode(data);
  if (result == null) {
    throw new Error("Invalid hex input");
  }
  return result;
}
