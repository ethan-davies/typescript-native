/** π as f64. */
export const PI: f64 = 3.141592653589793;

/** Euler's number e as f64. */
export const E: f64 = 2.718281828459045;

/** τ = 2π as f64. */
export const TAU: f64 = 6.283185307179586;

/** @deprecated Prefer PI */
export function pi(): f64 {
  return PI;
}

/** @deprecated Prefer E */
export function e(): f64 {
  return E;
}
