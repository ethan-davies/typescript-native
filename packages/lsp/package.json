{
  "name": "@sonite/lsp",
  "version": "0.0.0",
  "description": "Language server for Sonite (.sn)",
  "license": "MIT",
  "type": "module",
  "bin": {
    "sn-lsp": "./dist/server.js"
  },
  "main": "./dist/server.js",
  "exports": {
    ".": "./dist/server.js",
    "./dist/server.js": "./dist/server.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "dev": "tsx src/server.ts --stdio"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@sonite/compiler": "workspace:*",
    "@sonite/std": "workspace:*",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
