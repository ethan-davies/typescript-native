{
  "name": "@sonite/runtime",
  "version": "0.0.0",
  "description": "C runtime library for sonite programs",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "include",
    "prebuilt"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "openssl": "node scripts/fetch-openssl.js",
    "build": "tsc -p tsconfig.build.json && make && node ./dist/install-prebuilt.js",
    "clean": "rm -rf dist && make clean",
    "test": "make test",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prebuilt:install": "tsc -p tsconfig.build.json && node ./dist/install-prebuilt.js"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "typescript": "^5.8.3"
  }
}
